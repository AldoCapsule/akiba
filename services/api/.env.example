# =============================================================================
# Akiba API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# Matches the credentials in docker-compose.yml for local development.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://akiba:akiba_dev_pass@localhost:5432/akiba_dev

# -----------------------------------------------------------------------------
# Redis — caching, rate-limiting, session store
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT — Authentication tokens
# Generate a strong secret: openssl rand -base64 48
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# -----------------------------------------------------------------------------
# PI-SPI (BCEAO) — WAEMU instant payment rails
# Docs: https://developer.pispi.bceao.int
# -----------------------------------------------------------------------------
PISPI_BASE_URL=https://sandbox.developer.pispi.bceao.int
PISPI_API_KEY=
PISPI_WEBHOOK_SECRET=
PISPI_PARTICIPANT_ID=

# -----------------------------------------------------------------------------
# KYC — Smile ID (identity verification for African markets)
# Dashboard: https://portal.usesmileid.com
# -----------------------------------------------------------------------------
SMILE_ID_API_KEY=
SMILE_ID_PARTNER_ID=

# -----------------------------------------------------------------------------
# SMS — Africa's Talking (OTP, notifications)
# Dashboard: https://account.africastalking.com
# -----------------------------------------------------------------------------
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=Akiba

# -----------------------------------------------------------------------------
# Push Notifications — Firebase Cloud Messaging
# Service account key from Firebase Console > Project Settings > Service Accounts
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# -----------------------------------------------------------------------------
# S3 — KYC document storage
# Using eu-west-3 (Paris) for GDPR proximity to Senegal/WAEMU
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=akiba-kyc-documents
