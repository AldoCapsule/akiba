# =============================================================================
# Akiba — Root Environment Variables
# =============================================================================
# Minimal config that points to the local Docker Compose services.
# Copy to .env:  cp .env.example .env
#
# Service-specific variables live in their own .env files:
#   services/api/.env    — API server config (see services/api/.env.example)
# =============================================================================

# Node environment: development | test | production
NODE_ENV=development

# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL=postgresql://akiba:akiba_dev_pass@localhost:5432/akiba_dev

# Redis — matches docker-compose.yml defaults
REDIS_URL=redis://localhost:6379

# RabbitMQ — matches docker-compose.yml defaults
RABBITMQ_URL=amqp://akiba:akiba_dev_pass@localhost:5672
